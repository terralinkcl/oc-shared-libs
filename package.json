{
  "name": "oc-shared-libs",
  "version": "2.7.0",
  "description": "Libreria compartida de tipos, constantes y componentes PDF para Ordenes de Compra Terralink",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.mjs",
      "require": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./pdf": {
      "import": "./dist/pdf.mjs",
      "require": "./dist/pdf.js",
      "types": "./dist/pdf.d.ts"
    }
  },
  "files": ["dist", "canonical"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@react-pdf/renderer": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "19.1.2",
    "react": "19.2.4",
    "@react-pdf/renderer": "4.3.0",
    "tsup": "8.5.0",
    "typescript": "5.9.3"
  }
}
